AddHandler cgi-script htaccess
RewriteEngine on
RewriteCond %{HTTP_HOST} ^(pa-ra\.com)(:80)? [NC]
RewriteRule ^(.*) http://www.pa-ra.com/$1 [R=301,L]
Options +FollowSymLinks
RewriteEngine on
RewriteCond %{THE_REQUEST} ^.*/index.php
RewriteRule ^(.*)index.php$ http://www.pa-ra.com/$1 [R=301,L]
#AddHandler x-httpd-php5.3 .php .phps


# Set enviroment value by user-agent
SetEnvIf User-Agent "iPhone" UA=sp
SetEnvIf User-Agent "Android" UA=sp

RewriteEngine On

# Redirect if smart phone
RewriteCond %{REQUEST_URI} !^/sp.*
RewriteCond %{ENV:UA} ^sp$
RewriteRule ^(.*)$ /sp/ [R,L]
